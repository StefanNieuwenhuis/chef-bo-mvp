// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------
// Households schema
// ---------------------------------------------------------------------
model Household {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)

  members HouseholdMember[]

  @@map("households")
}

// ---------------------------------------------------------------------
// Household members schema
// ---------------------------------------------------------------------
model HouseholdMember {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  householdId  String    @map("household_id") @db.Uuid
  name         String
  allergies    Json?     @map("allergies") @db.JsonB
  dietaryRules Json?     @map("dietary_rules") @db.JsonB
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime? @updatedAt @map("updated_at") @db.Timestamptz(6)
  household    Household @relation(fields: [householdId], references: [id], onDelete: Cascade)

  personalAgent PersonalAgent?

  @@index([householdId])
  @@map("household_members")
}

// ---------------------------------------------------------------------
// Personal agents schema
// ---------------------------------------------------------------------
enum AgentStatus {
  PENDING
  ACTIVE
  FAILED
}

model PersonalAgent {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  householdMemberId String          @unique @map("household_member_id") @db.Uuid
  name              String
  status            AgentStatus     @default(PENDING)
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime?       @updatedAt @map("updated_at") @db.Timestamptz(6)
  householdMember   HouseholdMember @relation(fields: [householdMemberId], references: [id], onDelete: Cascade)

  @@map("personal_agents")
}
